#!/usr/bin/env bash
set -Eeuo pipefail

usage() {
  cat <<'USAGE'
paxelize: stage local agent history for Paxel

Usage:
  paxelize doctor
  paxelize stage [--stage-dir DIR] [--current-link DIR] [--dry-run]
  paxelize counts [--current-link DIR]
  paxelize audit [--current-link DIR]
  paxelize env [--current-link DIR]
  paxelize run [--current-link DIR] [--paxel-url URL] [-- PAXEL_ARGS...]
  paxelize clean [--current-link DIR]

Environment:
  PAXELIZE_STAGE_DIR    Exact stage directory to create.
  PAXELIZE_CURRENT      Stable symlink path.
  PAXELIZE_PAXEL_URL    Paxel upload script URL.
USAGE
}

die() {
  echo "error: $*" >&2
  exit 1
}

warn() {
  echo "warning: $*" >&2
}

home="${HOME:?}"
paxel_home="$home/.paxel"
current="${PAXELIZE_CURRENT:-$paxel_home/all-agent-history-current}"
paxel_url="${PAXELIZE_PAXEL_URL:-https://paxel.ycombinator.com/upload.sh}"

command_name="${1:-}"
[ -n "$command_name" ] || { usage; exit 1; }
shift || true

stage_dir="${PAXELIZE_STAGE_DIR:-}"
dry_run=0
paxel_args=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --)
      shift
      paxel_args=("$@")
      break
      ;;
    --stage-dir)
      [ "$#" -ge 2 ] || die "--stage-dir needs a value"
      stage_dir="$2"
      shift 2
      ;;
    --current-link)
      [ "$#" -ge 2 ] || die "--current-link needs a value"
      current="$2"
      shift 2
      ;;
    --paxel-url)
      [ "$#" -ge 2 ] || die "--paxel-url needs a value"
      paxel_url="$2"
      shift 2
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

timestamp() {
  date +%Y%m%d-%H%M%S
}

human_count() {
  tr -d ' '
}

count_jsonl() {
  local dir="$1"
  [ -d "$dir" ] || { echo 0; return; }
  find "$dir" -name '*.jsonl' -type f 2>/dev/null | wc -l | human_count
}

count_opencode_sessions() {
  local db="$1"
  [ -f "$db" ] || { echo 0; return; }
  command -v sqlite3 >/dev/null 2>&1 || { echo "unknown"; return; }
  sqlite3 "$db" 'select count(*) from session;' 2>/dev/null || echo "unknown"
}

source_report() {
  local claude_transcripts="$home/.claude/transcripts"
  local claude_projects="$home/.claude/projects"
  local codex_sessions="$home/.codex/sessions"
  local codex_archived="$home/.codex/archived_sessions"
  local opencode_db="$home/.local/share/opencode/opencode.db"

  echo "Sources:"
  printf '  %-28s %s\n' "Claude transcripts:" "$(count_jsonl "$claude_transcripts") JSONL"
  printf '  %-28s %s\n' "Claude projects:" "$(count_jsonl "$claude_projects") JSONL"
  printf '  %-28s %s\n' "Codex sessions:" "$(count_jsonl "$codex_sessions") JSONL"
  printf '  %-28s %s\n' "Codex archived:" "$(count_jsonl "$codex_archived") JSONL"
  printf '  %-28s %s\n' "opencode:" "$(count_opencode_sessions "$opencode_db") sessions"
  echo
  echo "Paths:"
  printf '  %s\n' "$claude_transcripts"
  printf '  %s\n' "$claude_projects"
  printf '  %s\n' "$codex_sessions"
  printf '  %s\n' "$codex_archived"
  printf '  %s\n' "$opencode_db"
}

copy_dir_contents() {
  local src="$1"
  local dst="$2"

  [ -d "$src" ] || return 0
  mkdir -p "$dst"
  rsync -a "$src"/ "$dst"/
}

stage_opencode_db() {
  local src="$1"
  local dst="$2"

  [ -f "$src" ] || return 0
  mkdir -p "$dst"

  if command -v sqlite3 >/dev/null 2>&1; then
    sqlite3 "$src" "VACUUM INTO '$dst/opencode.db';"
  else
    warn "sqlite3 not found; skipping opencode DB snapshot"
  fi
}

stage_history() {
  local target="$1"

  mkdir -p "$target"/{claude/desktop-transcripts,codex,opencode}
  chmod 700 "$paxel_home" "$target" 2>/dev/null || true

  copy_dir_contents "$home/.claude/transcripts" "$target/claude/desktop-transcripts"
  copy_dir_contents "$home/.claude/projects" "$target/claude/projects"
  copy_dir_contents "$home/.codex/sessions" "$target/codex/sessions"
  copy_dir_contents "$home/.codex/archived_sessions" "$target/codex/archived_sessions"
  stage_opencode_db "$home/.local/share/opencode/opencode.db" "$target/opencode"

  ln -sfn "$target" "$current"
}

print_env_command() {
  local root="$1"

  printf 'CLAUDE_DIR=%q CODEX_DIR=%q OPENCODE_DIR=%q curl -fsSL %q | bash -s --' \
    "$root/claude" "$root/codex" "$root/opencode" "$paxel_url"
  if [ "${#paxel_args[@]}" -gt 0 ]; then
    printf ' %q' "${paxel_args[@]}"
  fi
  printf '\n'
}

stage_report() {
  local root="$1"

  echo "Staged Paxel agent history at: $(readlink "$current" 2>/dev/null || echo "$root")"
  echo "Stable symlink: $current"
  echo
  echo "Counts:"
  printf '  %-14s %s\n' "Claude JSONL:" "$(count_jsonl "$root/claude")"
  printf '  %-14s %s\n' "Codex JSONL:" "$(count_jsonl "$root/codex")"
  local opencode_db_count
  opencode_db_count="$(find "$root/opencode" -maxdepth 1 -name 'opencode*.db' -type f 2>/dev/null | wc -l | human_count)"
  printf '  %-14s %s\n' "opencode DBs:" "$opencode_db_count"
  echo
  echo "Run Paxel with:"
  print_env_command "$root"
}

case "$command_name" in
  doctor)
    source_report
    ;;
  stage)
    command -v rsync >/dev/null 2>&1 || die "rsync is required"
    mkdir -p "$paxel_home"
    chmod 700 "$paxel_home" 2>/dev/null || true
    if [ -z "$stage_dir" ]; then
      stage_dir="$paxel_home/all-agent-history-$(timestamp)"
    fi
    if [ "$dry_run" -eq 1 ]; then
      source_report
      echo
      echo "Would stage into: $stage_dir"
      echo "Would update symlink: $current"
      exit 0
    fi
    stage_history "$stage_dir"
    stage_report "$current"
    ;;
  env)
    [ -d "$current" ] || die "missing staged history at $current; run 'paxelize stage' first"
    print_env_command "$current"
    ;;
  counts)
    [ -d "$current" ] || die "missing staged history at $current; run 'paxelize stage' first"
    stage_report "$current"
    ;;
  audit)
    [ -d "$current" ] || die "missing staged history at $current; run 'paxelize stage' first"
    command -v python3 >/dev/null 2>&1 || die "python3 is required for audit"
    python3 - "$current/codex" <<'PY'
import json
import pathlib
import collections
import subprocess
import os
import sys

root = pathlib.Path(sys.argv[1])
rows = []

for path in root.rglob("*.jsonl"):
    try:
        with path.open("r", encoding="utf-8") as f:
            first = json.loads(f.readline())
    except Exception as exc:
        rows.append({"path": str(path), "error": str(exc)})
        continue

    payload = first.get("payload", first)
    cwd = payload.get("cwd") or ""
    remote = (payload.get("git") or {}).get("repository_url") or ""
    rows.append({
        "path": str(path),
        "cwd": cwd,
        "remote": remote,
        "originator": payload.get("originator") or "",
        "timestamp": payload.get("timestamp") or "",
    })

def normalize(remote: str) -> str:
    remote = remote.strip()
    for prefix in ("ssh://", "https://", "http://"):
        if remote.startswith(prefix):
            remote = remote[len(prefix):]
    if remote.startswith("git@") and ":" in remote:
        host, rest = remote[4:].split(":", 1)
        remote = f"{host}/{rest}"
    if remote.endswith(".git"):
        remote = remote[:-4]
    return remote.rstrip("/")

def git_remote(cwd: str) -> str:
    if not cwd or not os.path.exists(cwd):
        return ""
    try:
        out = subprocess.check_output(
            ["git", "-C", cwd, "remote", "get-url", "origin"],
            stderr=subprocess.DEVNULL,
            text=True,
        ).strip()
    except Exception:
        return ""
    return out

errors = [r for r in rows if "error" in r]
valid = [r for r in rows if "error" not in r]
with_remote = [r for r in valid if r["remote"]]
without_remote = [r for r in valid if not r["remote"]]
worktrees = [r for r in valid if "/.codex/worktrees/" in r["cwd"]]

resolved_without_remote = []
unresolved_without_remote = []
for row in without_remote:
    fallback = git_remote(row["cwd"])
    if fallback:
        row["fallback_remote"] = fallback
        resolved_without_remote.append(row)
    else:
        unresolved_without_remote.append(row)

group_counts = collections.Counter()
for row in with_remote:
    group_counts[normalize(row["remote"])] += 1
for row in resolved_without_remote:
    group_counts[normalize(row["fallback_remote"])] += 1
for row in unresolved_without_remote:
    group_counts["(unattributed)"] += 1

print("Codex audit")
print(f"  JSONL files:              {len(rows)}")
print(f"  parse errors:             {len(errors)}")
print(f"  with repository_url:      {len(with_remote)}")
print(f"  without repository_url:   {len(without_remote)}")
print(f"  fallback-resolved cwd:    {len(resolved_without_remote)}")
print(f"  unresolved/unattributed:  {len(unresolved_without_remote)}")
print(f"  cwd under worktrees:      {len(worktrees)}")
print()
print("Groups Paxel should see after remote normalization:")
for remote, count in group_counts.most_common():
    print(f"  {count:4}  {remote}")

if unresolved_without_remote:
    print()
    print("Unresolved sessions:")
    for row in unresolved_without_remote:
        print(f"  {row['path']}")
        print(f"    cwd: {row['cwd'] or '(missing)'}")
PY
    ;;
  run)
    command -v curl >/dev/null 2>&1 || die "curl is required"
    [ -d "$current" ] || die "missing staged history at $current; run 'paxelize stage' first"
    export CLAUDE_DIR="$current/claude"
    export CODEX_DIR="$current/codex"
    export OPENCODE_DIR="$current/opencode"
    bash -s -- "${paxel_args[@]}" < <(curl -fsSL "$paxel_url")
    ;;
  clean)
    if [ -L "$current" ]; then
      target="$(readlink "$current")"
      rm -f "$current"
      [ -n "${target:-}" ] && [ -d "$target" ] && rm -rf "$target"
      echo "Removed $current and $target"
    elif [ -d "$current" ]; then
      rm -rf "$current"
      echo "Removed $current"
    else
      echo "Nothing to clean at $current"
    fi
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
